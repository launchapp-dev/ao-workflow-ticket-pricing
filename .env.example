# No external API keys required for core functionality.
# The following are optional for enhanced integrations:

# Ticketing platform API (for applying price changes in production)
# TICKETMASTER_API_KEY=your_api_key_here
# AXS_API_KEY=your_api_key_here

# If using a custom ticketing system
# TICKETING_API_URL=https://api.yourticketing.com
# TICKETING_API_TOKEN=your_token_here
